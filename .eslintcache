rizontal\">\r\n        <li key=\"pch\" className=\"list-group-item list-group-item-dark\">\r\n          Production Companies\r\n        </li>\r\n        {movie.production_companies.map(pc => (\r\n          <li key={pc.name} className=\"list-group-item\">\r\n            {pc.name}\r\n          </li>\r\n        ))}\r\n      </ul>\r\n      <ul className=\"list-group list-group-horizontal\">\r\n        <li key=\"pco\" className=\"list-group-item list-group-item-dark\">\r\n          Production Countries\r\n        </li>\r\n        {movie.production_countries.map(pco => (\r\n          <li key={pco.name} className=\"list-group-item\">\r\n            {pco.name}\r\n          </li>\r\n        ))}\r\n      </ul>\r\n    </>\r\n  );\r\n};\r\n","C:\\college\\temp_web\\moviesApp\\src\\pages\\movieDetailsPage.js",[],"C:\\college\\temp_web\\moviesApp\\src\\api\\stubAPI.js",[],"C:\\college\\temp_web\\moviesApp\\src\\pages\\favouriteMoviesPage.js",[],"C:\\college\\temp_web\\moviesApp\\src\\api\\tmdb-api.js",[],"C:\\college\\temp_web\\moviesApp\\src\\components\\templateMovieListPage\\index.js",[],{"ruleId":"67","replacedBy":"68"},{"ruleId":"69","replacedBy":"70"},{"ruleId":"67","replacedBy":"71"},{"ruleId":"69","replacedBy":"72"},{"ruleId":"73","severity":1,"message":"74","line":12,"column":6,"nodeType":"75","endLine":12,"endColumn":8,"suggestions":"76"},{"ruleId":"77","severity":1,"message":"78","line":4,"column":1,"nodeType":"79","endLine":66,"endColumn":3},"no-native-reassign",["80"],"no-negated-in-lhs",["81"],["80"],["81"],"react-hooks/exhaustive-deps","React Hook useEffect has a missing dependency: 'genres'. Either include it or remove the dependency array. You can also do a functional update 'setGenres(g => ...)' if you only need 'genres' in the 'setGenres' call.","ArrayExpression",["82"],"import/no-anonymous-default-export","Assign arrow function to a variable before exporting as module default","ExportDefaultDeclaration","no-global-assign","no-unsafe-negation",{"desc":"83","fix