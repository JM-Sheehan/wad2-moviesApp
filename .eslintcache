ssages":"91","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"92","messages":"93","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"94","messages":"95","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"96","messages":"97","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"C:\\college\\temp_web\\moviesApp\\src\\components\\movieCard\\index.js",[],["98","99"],"C:\\college\\temp_web\\moviesApp\\src\\globals\\fontawesome.js",[],"C:\\college\\temp_web\\moviesApp\\src\\components\\filterControls\\index.js",["100"],"import React, { useState, useEffect } from \"react\";\r\nimport \"./filterControls.css\";\r\nimport { getGenres } from \"../../api/tmdb-api\";\r\n\r\nconst FilterControls = props => {\r\n  const [genres, setGenres] = useState([{ id: '0', name: \"All\" }])\r\n\r\n  useEffect(() => {\r\n    getGenres().then(allGenres => {\r\n      setGenres([genres[0], ...allGenres]);\r\n    });\r\n  }, []);\r\n\r\n  const handleChange = (e, type, value) => {\r\n    e.preventDefault()\r\n    props.onUserInput(type, value)   // NEW\r\n  };\r\n  const handleTextChange = e => {\r\n    handleChange(e, \"name\", e.target.value)\r\n  }\r\n  const handleGenreChange = e => {\r\n    handleChange(e, \"genre\", e.target.value)\r\n  };\r\n\r\n  return (\r\n      <div className=\"row bg-warning\">\r\n        <div className=\"col-md-12\">\r\n          <h4>\r\n            <span>List Filtering:</span>\r\n            <input\r\n              type=\"text\"\r\n              placeholder=\"Title Search\"\r\n              onChange={handleTextChange}\r\n            />\r\n          <select id=\"genre\" onChange={handleGenreChange}>\r\n              {genres.map(genre => {\r\n                return (\r\n                  <option key={genre.id} value={genre.id}>\r\n                    {genre.name}\r\n                  </option>\r\n                );\r\n              })}\r\n          </select>\r\n         </h4>\r\n        </div>\r\n      </div>\r\n  );\r\n}\r\n\r\nexport default FilterControls;","C:\\college\\temp_web\\moviesApp\\src\\components\\headerMovieList\\index.js",[],"C:\\college\\temp_web\\moviesApp\\src\\components\\movieList\\index.js",[],"C:\\college\\temp_web\\moviesApp\\src\\index.js",["101"],"C:\\college\\temp_web\\moviesApp\\src\\pages\\homePage.js",[],"C:\\college\\temp_web\\moviesApp\\src\\components\\headerMovie\\index.js",[],"C:\\college\\temp_web\\moviesApp\\src\\components\\movieDetails\\index.js",["102"],"import React from \"react\";\r\nimport \"./movieDetails.css\";\r\n\r\nexport default ({ movie }) => {\r\n  return (\r\n    <>\r\n      <h4>Overview</h4>\r\n      <p>{movie.overview}</p>\r\n      <ul className=\"list-group list-group-horizontal\">\r\n        <li key=\"ruh\" className=\"list-group-item list-group-item-dark\">\r\n          Runtime (min.)\r\n        </li>\r\n        <li key=\"rut\" className=\"list-group-item \">\r\n          {movie.runtime}\r\n        </li>\r\n        <li key=\"rdh\" className=\"list-group-item list-group-item-dark\">\r\n          Release Date\r\n        </li>\r\n        <li key=\"rdv\" className=\"list-group-item \">\r\n          {movie.release_date}\r\n        </li>\r\n      </ul>\r\n\r\n      <ul className=\"list-group list-group-horizontal\">\r\n        <li key=\"gh\" className=\"list-group-item list-group-item-dark\">\r\n          Genres\r\n        </li>\r\n        {movie.genres.map(g => (\r\n          <li key={g.name} className=\"list-group-item\">\r\n            {g.name}\r\n          </li>\r\n        ))}\r\n      </ul>\r\n      <ul className=\"list-group list-group-horizontal\">\r\n        <li key=\"slh\" className=\"list-group-item list-group-item-dark\">\r\n          Spoken Languages\r\n        </li>\r\n        {movie.spoken_languages.map(lang => (\r\n          <li key={lang.name} className=\"list-group-item\">\r\n            {lang.name}\r\n          </li>\r\n        ))}\r\n      </ul>\r\n      <ul className=\"list-group list-group-horizontal\">\r\n        <li key=\"pch\" className=\"list-group-item list-group-item-dark\">\r\n          Production Companies\r\n        </li>\r\n        {movie.production_companies.map(pc => (\r\n          <li key={pc.name} className=\"list-group-item\">\r\n            {pc.name}\r\n          </li>\r\n        ))}\r\n      </ul>\r\n      <ul className=\"list-group list-group-horizontal\">\r\n        <li key=\"pco\" className=\"list-group-item list-group-item-dark\">\r\n          Production Countries\r\n        </li>\r\n        {movie.production_countries.map(pco => (\r\n          <li key={pco.name} className=\"list-group-item\">\r\n            {pco.name}\r\n          </li>\r\n        ))}\r\n      </ul>\r\n    </>\r\n  );\r\n};\r\n","C:\\college\\temp_web\\moviesApp\\src\\pages\\movieDetailsPage.js",[],"C:\\college\\temp_web\\moviesApp\\src\\api\\stubAPI.js",[],"C:\\college\\temp_web\\moviesApp\\src\\pages\\favouriteMoviesPage.js",[],"C:\\college\\temp_web\\moviesApp\\src\\api\\tmdb-api.js",[],"C:\\college\\temp_web\\moviesApp\\src\\components\\templateMovieListPage\\index.js",[],"C:\\college\\temp_web\\moviesApp\\src\\pages\\movieReviewPage.js",[],"C:\\college\\temp_web\\moviesApp\\src\\components\\templateMoviePage\\index.js",[],"C:\\college\\temp_web\\moviesApp\\src\\components\\movieReviews\\index.js",["103"],"import React from \"react\";\r\n\r\nexport default ({ review }) => {\r\n  return (\r\n    <>\r\n      <p>Review By: {review.author} </p>\r\n      <p>{review.content} </p>\r\n    </>\r\n  );\r\n};","C:\\college\\temp_web\\moviesApp\\src\\util.js",[],"C:\\college\\temp_web\\moviesApp\\src\\components\\movieReview\\index.js",["104"],"C:\\college\\temp_web\\moviesApp\\src\\components\\siteHeader\\index.js",[],"C:\\college\\temp_web\\moviesApp\\src\\hooks\\useMovie.js",[],"C:\\college\\temp_web\\moviesApp\\src\\contexts\\genresContext.js",[],"C:\\college\\temp_web\\moviesApp\\src\\