 path=\"/movies/upcoming\" component={UpcomingMoviesPage} />\r\n                <Route path=\"/movies/:id\" component={MoviePage} />\r\n                <Route path=\"/\" component={HomePage} />\r\n                <Route path=\"/reviews/:id\" component={MovieReviewPage} />\r\n                <Redirect from=\"*\" to=\"/\" />\r\n              </Switch>\r\n            </GenresContextProvider>    {/* NEW */}\r\n          </MoviesContextProvider>\r\n        </div>\r\n      </div>\r\n    </BrowserRouter>\r\n  );\r\n};\r\n\r\nReactDOM.render(<App />, document.getElementById(\"root\"));","C:\\college\\temp_web\\moviesApp\\src\\pages\\homePage.js",[],"C:\\college\\temp_web\\moviesApp\\src\\components\\headerMovie\\index.js",[],"C:\\college\\temp_web\\moviesApp\\src\\components\\movieDetails\\index.js",["126"],"import React from \"react\";\r\nimport \"./movieDetails.css\";\r\n\r\nexport default ({ movie }) => {\r\n  return (\r\n    <>\r\n      <h4>Overview</h4>\r\n      <p>{movie.overview}</p>\r\n      <ul className=\"list-group list-group-horizontal\">\r\n        <li key=\"ruh\" className=\"list-group-item list-group-item-dark\">\r\n          Runtime (min.)\r\n        </li>\r\n        <li key=\"rut\" className=\"list-group-item \">\r\n          {movie.runtime}\r\n        </li>\r\n        <li key=\"rdh\" className=\"list-group-item list-group-item-dark\">\r\n          Release Date\r\n        </li>\r\n        <li key=\"rdv\" className=\"list-group-item \">\r\n          {movie.release_date}\r\n        </li>\r\n      </ul>\r\n\r\n      <ul className=\"list-group list-group-horizontal\">\r\n        <li key=\"gh\" className=\"list-group-item list-group-item-dark\">\r\n          Genres\r\n        </li>\r\n        {movie.genres.map(g => (\r\n          <li key={g.name} className=\"list-group-item\">\r\n            {g.name}\r\n          </li>\r\n        ))}\r\n      </ul>\r\n      <ul className=\"list-group list-group-horizontal\">\r\n        <li key=\"slh\" className=\"list-group-item list-group-item-dark\">\r\n          Spoken Languages\r\n        </li>\r\n        {movie.spoken_languages.map(lang => (\r\n          <li key={lang.name} className=\"list-group-item\">\r\n            {lang.name}\r\n          </li>\r\n        ))}\r\n      </ul>\r\n      <ul className=\"list-group list-group-horizontal\">\r\n        <li key=\"pch\" className=\"list-group-item list-group-item-dark\">\r\n          Production Companies\r\n        </li>\r\n        {movie.production_companies.map(pc => (\r\n          <li key={pc.name} className=\"list-group-item\">\r\n            {pc.name}\r\n          </li>\r\n        ))}\r\n      </ul>\r\n      <ul className=\"list-group list-group-horizontal\">\r\n        <li key=\"pco\" className=\"list-group-item list-group-item-dark\">\r\n          Production Countries\r\n        </li>\r\n        {movie.production_countries.map(pco => (\r\n          <li key={pco.name} className=\"list-group-item\">\r\n            {pco.name}\r\n          </li>\r\n        ))}\r\n      </ul>\r\n    </>\r\n  );\r\n};\r\n","C:\\college\\temp_web\\moviesApp\\src\\pages\\movieDetailsPage.js",[],"C:\\college\\temp_web\\moviesApp\\src\\api\\stubAPI.js",[],["127","128"],"C:\\college\\temp_web\\moviesApp\\src\\pages\\favouriteMoviesPage.js",[],"C:\\college\\temp_web\\moviesApp\\src\\api\\tmdb-api.js",[],"C:\\college\\temp_web\\moviesApp\\src\\components\\templateMovieListPage\\index.js",[],"C:\\college\\temp_web\\moviesApp\\src\\pages\\movieReviewPage.js",[],"C:\\college\\temp_web\\moviesApp\\src\\components\\templateMoviePage\\index.js",[],"C:\\college\\temp_web\\moviesApp\\src\\components\\movieReviews\\index.js",["129"],"import React from \"react\";\r\n\r\nexport default ({ review }) => {\r\n  return (\r\n    <>\r\n      <p>Review By: {review.author} </p>\r\n      <p>{review.content} </p>\r\n    </>\r\n  );\r\n};","C:\\college\\temp_web\\moviesApp\\src\\util.js",[],"C:\\college\\temp_web\\moviesApp\\src\\components\\movieReview\\index.js",["130"],"C:\\colleg