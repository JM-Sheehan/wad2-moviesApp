ect } from \"react\";\r\nimport \"./filterControls.css\";\r\nimport { getGenres } from \"../../api/tmdb-api\";\r\n\r\nconst FilterControls = props => {\r\n  const [genres, setGenres] = useState([{ id: '0', name: \"All\" }])\r\n\r\n  useEffect(() => {\r\n    getGenres().then(allGenres => {\r\n      setGenres([genres[0], ...allGenres]);\r\n    });\r\n  }, []);\r\n\r\n  const handleChange = (e, type, value) => {\r\n    e.preventDefault()\r\n    props.onUserInput(type, value)   // NEW\r\n  };\r\n  const handleTextChange = e => {\r\n    handleChange(e, \"name\", e.target.value)\r\n  }\r\n  const handleGenreChange = e => {\r\n    handleChange(e, \"genre\", e.target.value)\r\n  };\r\n\r\n  return (\r\n      <div className=\"row bg-warning\">\r\n        <div className=\"col-md-12\">\r\n          <h4>\r\n            <span>List Filtering:</span>\r\n            <input\r\n              type=\"text\"\r\n              placeholder=\"Title Search\"\r\n              onChange={handleTextChange}\r\n            />\r\n          <select id=\"genre\" onChange={handleGenreChange}>\r\n              {genres.map(genre => {\r\n                return (\r\n                  <option key={genre.id} value={genre.id}>\r\n                    {genre.name}\r\n                  </option>\r\n                );\r\n              })}\r\n          </select>\r\n         </h4>\r\n        </div>\r\n      </div>\r\n  );\r\n}\r\n\r\nexport default FilterControls;","C:\\college\\temp_web\\moviesApp\\src\\components\\headerMovieList\\index.js",[],"C:\\college\\temp_web\\moviesApp\\src\\components\\movieList\\index.js",[],"C:\\college\\temp_web\\moviesApp\\src\\index.js",["119"],"import React from \"react\";\r\nimport ReactDOM from \"react-dom\";\r\nimport \"../node_modules/bootstrap/dist/css/bootstrap.css\";\r\nimport HomePage from \"./pages/homePage\";\r\nimport MoviePage from './pages/movieDetailsPage';\r\nimport { BrowserRouter, Route, Redirect, Switch, Link } from \"react-router-dom\";  // CHANGED\r\nimport FavoriteMoviesPage from \"./pages/favouriteMoviesPage\";       // NEW\r\nimport MovieReviewPage from \"./pages/movieReviewPage\";\r\nimport SiteHeader from './components/siteHeader';\r\nimport MoviesContextProvider from \"./contexts/moviesContext\";\r\nimport GenresContextProvider from \"./contexts/genresContext\";\r\nimport AddMovieReviewPage from './pages/addMovieReviewPage';\r\n\r\nconst App = () => {\r\n  return (\r\n    <BrowserRouter>\r\n      <div className=\"jumbotron\">\r\n        <SiteHeader />\r\n        <div className=\"container-fluid\">\r\n          <MoviesContextProvider>\r\n            <GenresContextProvider>    {/* NEW */}\r\n              <Switch>\r\n                <Route exact path=\"/reviews/form\" component={AddMovieReviewPage} />\r\n                <Route exact path=\"/movies/favorites\" component={FavoriteMoviesPage} />\r\n                <Route path=\"/movies/:id\" component={MoviePage} />\r\n                <Route path=\"/\" component={HomePage} />\r\n                <Route path=\"/reviews/:id\" component={MovieReviewPage} />\r\n                <Redirect from=\"*\" to=\"/\" />\r\n              </Switch>\r\n            </GenresContextProvider>    {/* NEW */}\r\n          </MoviesContextProvider>\r\n        </div>\r\n      </div>\r\n    </BrowserRouter>\r\n  );\r\n};\r\n\r\nReactDOM.render(<App />, document.getElementById(\"root\"));","C:\\college\\temp_web\\moviesApp\\src\\pages\\homePage.js",[],"C:\\college\\temp_web\\moviesApp\\src\\components\\headerMovie\\index.js",[],"C:\\college\\temp_web\\moviesApp\\src\\components\\movieDetails\\index.js",["120"],"import React from \"react\";\r\nimport \"./movieDetails.css\";\r\n\r\nexport default ({ movie }) => {\r\n  return (\r\n    <>\r\n      <h4>Overview</h4>\r\n      <p>{movie.overview}</p>\r\n      <ul className=\"list-group list-group-horizontal\">\r\n        <li key=\"ruh\" className=\"list-group-item list-group-item-dark\">\r\n          Runtime (min.)\r\n        </li>\r\n        <li key=\"rut\" className=\"list-group-item \">\r\n          {movie.runtime}\r\n        </li>\r\n        <li key=\"rdh\" className=\"list-group-item list-group-item-dark\">\r\n          Release Date\r\n        </li>\r\n        <li key=\"rdv\" className=\"list-group-item \">\r\n          {movie.release_date}\r\n        </li>\r\n      </ul>\r\n\r\n      <ul className=\"list-group list-group-horizontal\">\r\n        <li key=\"gh\" className=\"list-group-item list-group-item-dark\">\r\n          Genres\r\n        </li>\r\n        {movie.genres.map(g => (\r\n          <li key={g.name} className=\"list-group-item\">\r\n            {g.name}\r\n          </li>\r\n        ))}\r\n      </ul>\r\n      <ul className=\"list-group list-group-horizontal\">\r\n        <li key=\"slh\" className=\"list-group-item list-group-item-dark\">\r\n          Spoken Languages\r\n        </li>\r\n        {movie.spoken_languages.map(lang => (\r\n          <li key={lang.name} className=\"list-group-item\">\r\n            {lang.name}\r\n          </li>\r\n        ))}\r\n      </ul>\r\n      <ul className=\"list-group list-group-horizontal\">\r\n        <li key=\"pch\" className=\"list-group-item list-group-item-dark\">\r\n          Production Companies\r\n        </li>\r\n        {movie.production_companies.map(pc => (\r\n          <li key={pc.name} className=\"list-group-item\">\r\n            {pc.name}\r\n          </li>\r\n        ))}\r\n      </ul>\r\n      <ul className=\"list-group list-group-horizontal\">\r\n        <li key=\"pco\" className=\"list-group-item list-group-item-dark\">\r\n          Production Countries\r\n        </li>\r\n        {movie.production_countries.map(pco => (\r\n          <li key={pco.name} className=\"list-group-item\">\r\n            {pco.name}\r\n          </li>\r\n        ))}\r\n      </ul>\r\n    </>\r\n  );\r\n};\r\n","C:\\college\\temp_web\\moviesApp\\src\\pages\\movieDetailsPage.js",[],"C:\\college\\temp_web\\moviesApp\\src\\api\\stubAPI.js",[],["121","122"],"C:\\college\