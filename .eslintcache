\n        process.env.REACT_APP_TMDB_KEY\r\n    )\r\n      .then(res => res.json())\r\n      .then(json => json.genres)\r\n      .then(apiGenres => {\r\n        setGenres([genres[0], ...apiGenres]);\r\n      });\r\n  }, []);\r\n\r\n  const handleChange = (e, type, value) => {\r\n    e.preventDefault()\r\n    props.onUserInput(type, value)   // NEW\r\n  };\r\n  const handleTextChange = e => {\r\n    handleChange(e, \"name\", e.target.value)\r\n  }\r\n  const handleGenreChange = e => {\r\n    handleChange(e, \"genre\", e.target.value)\r\n  };\r\n\r\n  return (\r\n      <div className=\"row bg-warning\">\r\n        <div className=\"col-md-12\">\r\n          <h4>\r\n            <span>List Filtering:</span>\r\n            <input\r\n              type=\"text\"\r\n              placeholder=\"Title Search\"\r\n              onChange={handleTextChange}\r\n            />\r\n          <select id=\"genre\" onChange={handleGenreChange}>\r\n              {genres.map(genre => {\r\n                return (\r\n                  <option key={genre.id} value={genre.id}>\r\n                    {genre.name}\r\n                  </option>\r\n                );\r\n              })}\r\n          </select>\r\n         </h4>\r\n        </div>\r\n      </div>\r\n  );\r\n}\r\n\r\nexport default FilterControls;","C:\\college\\temp_web\\moviesApp\\src\\components\\headerMovieList\\index.js",[],"C:\\college\\temp_web\\moviesApp\\src\\components\\movieList\\index.js",[],"C:\\college\\temp_web\\moviesApp\\src\\index.js",[],"C:\\college\\temp_web\\moviesApp\\src\\pages\\homePage.js",[],"C:\\college\\temp_web\\moviesApp\\src\\components\\headerMovie\\index.js",[],"C:\\college\\temp_web\\moviesApp\\src\\components\\movieDetails\\index.js",["59"],"import React from \"react\";\r\nimport \"./movieDetails.css\";\r\n\r\nexport default ({ movie }) => {\r\n  return (\r\n    <>\r\n      <h4>Overview</h4>\r\n      <p>{movie.overview}</p>\r\n      <ul className=\"list-group list-group-horizontal\">\r\n        <li key=\"ruh\" className=\"list-group-item list-group-item-dark\">\r\n          Runtime (min.)\r\n        </li>\r\n        <li key=\"rut\" className=\"list-group-item \">\r\n          {movie.runtime}\r\n        </li>\r\n        <li key=\"rdh\" className=\"list-group-item list-group-item-dark\">\r\n          Release Date\r\n        </li>\r\n        <li key=\"rdv\" className=\"list-group-item \">\r\n          {movie.release_date}\r\n        </li>\r\n      </ul>\r\n\r\n      <ul className=\"list-group list-group-horizontal\">\r\n        <li key=\"gh\" className=\"list-group-item list-group-item-dark\">\r\n          Genres\r\n        </li>\r\n        {movie.genres.map(g => (\r\n          <li key={g.name} className=\"list-group-item\">\r\n            {g.name}\r\n          </li>\r\n        ))}\r\n      </ul>\r\n      <ul className=\"list-group list-group-horizontal\">\r\n        <li key=\"slh\" className=\"list-group-item list-group-item-dark\">\r\n          Spoken Languages\r\n        </li>\r\n        {movie.spoken_languages.map(lang => (\r\n          <li key={lang.name} className=\"list-group-item\">\r\n            {lang.name}\r\n          </li>\r\n        ))}\r\n      </ul>\r\n      <ul className=\"list-group list-group-horizontal\">\r\n        <li key=\"pch\" className=\"list-group-item list-group-item-dark\">\r\n          Production Companies\r\n        </li>\r\n        {movie.production_companies.map(pc => (\r\n          <li key={pc.name} className=\"list-group-item\">\r\n            {pc.name}\r\n          </li>\r\n        ))}\r\n      </ul>\r\n      <ul className=\"list-group list-group-horizontal\">\r\n        <li key=\"pco\" className=\"list-group-item list-group-item-dark\">\r\n          Production Countries\r\n        </li>\r\n        {movie.production_countries.map(pco => (\r\n          <li key={pco.name} className=\"list-group-item\">\r\n            {pco.name}\r\n          </li>\r\n        ))}\r\n      </ul>\r\n    </>\r\n  );\r\n};\r\n","C:\\college\\temp_web\\moviesApp\\src\\pages\\movieDetailsPage.js",[],"C:\\college\\temp_web\\moviesApp\\src\\api\\stubAPI.js",[],"C:\\college\\temp_web\\moviesApp\\src\\pages\\favouriteMoviesPage.js",[],{"ruleId":"60","replacedBy":"61"},{"ruleId":"62","replacedBy":"63"},{"ruleId":"60","replacedBy":"64"},{"ruleId":"62","replacedBy":"65"},{"ruleId":"66","severity":1,"message":"67","line":17,"column":6,"nodeType":"68","endLine":17,"endColumn":8,"suggestions":"69"},{"ruleId":"70","severity":1,"message":"71","line":4,"column":1,"nodeType":"72","endLine":66,"endColumn":3},"no-native-reassign",["73"],"no-negated-in-lhs",["74"],["73"],["74"],"react-hooks/exhaustive-deps","React Hook useEffect has a missing dependency: 'genres'. Either include it or remove the dependency array. You can also do a functional update 'setGenres(g => ...)' if you only need 'genres' in the 'setGenres' call.","ArrayExpression",["75"],"import/no-anonymous-default-export","Assign arrow function to a variable before exporting as module default","ExportDefaultDeclaration","no-global-assign","no-unsafe-negation",{"desc":"76","fix":"77"},"Update the dependencies array to be: [genres]",{"range":"78","text":"79"},[495,497],"[genres]"]